<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ resume.name }} - Executive Engineering Leader</title>
  {% include "ga.njk" %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      /* Dynamic Light Glassmorphic Theme */
      --color-bg: #f8fafc;
      --color-text-main: #0f172a;
      --color-text-muted: #475569;
      --color-text-light: #94a3b8;

      --glass-bg: rgba(255, 255, 255, 0.4);
      --glass-border: rgba(255, 255, 255, 0.6);
      --glass-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05);

      --accent-1: #1e3a8a; /* Dark Navy Blue */
      --accent-2: #0d9488; /* Teal */
      --accent-3: #3b82f6; /* Royal Blue */

      --company-google: #4285f4;
      --company-facebook: #1877f2;
      --company-groupon: #53a318;
      --company-amazon: #ff9900;
      --company-microsoft: #00a4ef;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Outfit', sans-serif;
      background-color: var(--color-bg);
      color: var(--color-text-main);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Animated Mesh Gradient Background */
    .bg-animation {
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      z-index: -1;
      overflow: hidden;
      background: var(--color-bg);
    }
    .blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.5;
      animation: float 20s infinite ease-in-out alternate;
    }
    .blob-1 {
      top: -10%; left: -10%;
      width: 50vw; height: 50vw;
      background: var(--accent-1);
      animation-delay: 0s;
    }
    .blob-2 {
      top: 40%; right: -20%;
      width: 40vw; height: 40vw;
      background: var(--accent-2);
      animation-delay: -5s;
    }
    .blob-3 {
      bottom: -20%; left: 20%;
      width: 45vw; height: 45vw;
      background: var(--accent-3);
      animation-delay: -10s;
    }

    @keyframes float {
      0% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(5%, 10%) scale(1.1); }
      66% { transform: translate(-5%, 5%) scale(0.9); }
      100% { transform: translate(0, 0) scale(1); }
    }

    /* Container and Glass Utility */
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .glass-panel {
      background: var(--glass-bg);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid var(--glass-border);
      border-radius: 24px;
      box-shadow: var(--glass-shadow);
    }

    header {
      padding: 2rem 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: relative;
      z-index: 10;
    }

    .logo {
      font-weight: 800;
      font-size: 1.5rem;
      letter-spacing: -0.05em;
      background: linear-gradient(135deg, var(--color-text-main), var(--accent-1));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .nav-links a {
      text-decoration: none;
      color: var(--color-text-muted);
      font-weight: 500;
      margin-left: 2rem;
      transition: color 0.3s;
      font-size: 1rem;
    }

    .nav-links a:hover {
      color: var(--accent-1);
    }

    /* Hero Section */
    .hero {
      min-height: 85vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
      z-index: 10;
      padding: 4rem 0;
    }

    .hero-badge {
      display: inline-block;
      padding: 0.5rem 1rem;
      border-radius: 50px;
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.9);
      color: var(--accent-1);
      font-weight: 600;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 2rem;
      box-shadow: 0 4px 15px rgba(0,0,0,0.03);
      animation: fadeInDown 1s ease both;
    }

    .hero-title {
      font-size: clamp(3.5rem, 8vw, 6rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 1.5rem;
      animation: fadeInUp 1s ease both 0.2s;
    }

    .hero-title span {
      background: linear-gradient(120deg, var(--accent-1), var(--accent-2));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .hero-subtitle {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.25rem, 3vw, 1.75rem);
      color: var(--color-text-muted);
      max-width: 600px;
      margin-bottom: 3rem;
      animation: fadeInUp 1s ease both 0.4s;
    }

    .stats-row {
      display: inline-flex;
      gap: 3rem;
      padding: 1.5rem 2.5rem;
      align-items: center;
      animation: fadeInUp 1s ease both 0.6s;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
    }

    .stat-val {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--color-text-main);
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .stat-label {
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-text-muted);
      font-weight: 600;
    }

    .stat-divider {
      width: 1px;
      height: 60px;
      background: var(--glass-border);
      margin: 0 0.5rem;
    }

    .hero-logos {
      display: flex;
      gap: 1.5rem;
      align-items: center;
      margin-top: 0.75rem;
    }

    .hero-logos img {
      width: 28px;
      height: 28px;
      opacity: 0.8;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .hero-logos img:hover {
      opacity: 1;
      transform: translateY(-2px);
    }

    /* Summary Highlights */
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin: 4rem 0 8rem;
    }

    .summary-card {
      padding: 2.5rem;
      transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .summary-card:hover {
      transform: translateY(-10px);
    }

    .summary-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      background: white;
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .summary-card h3 {
      font-size: 1.25rem;
      margin-bottom: 1rem;
      color: var(--color-text-main);
    }

    .summary-card p {
      color: var(--color-text-muted);
      font-size: 0.95rem;
    }

    /* Section Headers */
    .section-title {
      font-size: 3rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 4rem;
      text-align: center;
    }

    /* Experience Timeline as elegant cards */
    .experience-section {
      padding: 6rem 0;
      position: relative;
    }

    .exp-track {
      position: relative;
    }

    .exp-track::before {
      content: '';
      position: absolute;
      top: 0; left: 40px; bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, rgba(30, 58, 138, 0.2), rgba(13, 148, 136, 0.2));
      z-index: 0;
      border-radius: 2px;
    }

    .exp-card {
      position: relative;
      margin-bottom: 4rem;
      padding-left: 100px;
    }

    .exp-logo-wrap {
      position: absolute;
      left: 10px;
      top: 0;
      width: 60px;
      height: 60px;
      background: white;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 20px rgba(0,0,0,0.06);
      z-index: 2;
      border: 1px solid rgba(0,0,0,0.05);
    }

    .exp-logo-img {
      max-width: 32px;
      max-height: 32px;
    }

    .exp-content {
      padding: 3rem;
      position: relative;
      transition: all 0.3s ease;
    }

    .exp-content:hover {
      background: rgba(255, 255, 255, 0.7);
    }

    .exp-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .company-name {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--color-text-main);
      margin-bottom: 0.25rem;
    }

    .company-meta {
      font-size: 0.9rem;
      color: var(--color-text-light);
      font-weight: 500;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .role-group {
      margin-bottom: 2rem;
    }

    .role-group:last-child {
      margin-bottom: 0;
    }

    .role-title {
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--accent-1);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .role-title span.period {
      font-size: 0.8rem;
      color: var(--color-text-light);
      font-weight: 500;
      padding: 0.2rem 0.6rem;
      background: rgba(0,0,0,0.03);
      border-radius: 4px;
    }

    .role-desc {
      list-style: none;
    }

    .role-desc li {
      position: relative;
      padding-left: 1.5rem;
      margin-bottom: 0.75rem;
      color: var(--color-text-muted);
      font-size: 0.95rem;
    }

    .role-desc li::before {
      content: '\2192';
      position: absolute;
      left: 0;
      color: var(--accent-2);
      font-weight: bold;
    }

    .role-title a, .role-desc a {
      color: var(--accent-1);
      text-decoration: none;
      border-bottom: 1px dashed var(--accent-2);
      transition: color 0.2s;
    }
    .role-title a:hover, .role-desc a:hover {
      color: var(--accent-2);
    }
    .role-title .period a {
      color: inherit;
    }

    .press-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;
    }

    .press-badge {
      font-size: 0.75rem;
      padding: 0.25rem 0.75rem;
      background: white;
      border: 1px solid rgba(0,0,0,0.05);
      border-radius: 50px;
      color: var(--color-text-muted);
      text-decoration: none;
      transition: all 0.2s;
      box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    }
    .press-badge:hover {
      border-color: var(--accent-1);
      color: var(--accent-1);
      transform: translateY(-2px);
    }

    /* Education Section */
    .edu-section {
      padding: 4rem 0 8rem;
    }

    .edu-card {
      display: flex;
      align-items: center;
      gap: 3rem;
      padding: 4rem;
      text-align: center;
      flex-direction: column;
    }

    .edu-year {
      font-size: 4rem;
      font-weight: 800;
      background: linear-gradient(to bottom, var(--color-text-light), transparent);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      opacity: 0.3;
      line-height: 1;
    }

    .edu-school {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-style: italic;
      color: var(--color-text-main);
      margin-bottom: 0.5rem;
    }

    .edu-degree {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--accent-1);
      margin-bottom: 1rem;
    }

    /* Contact Form */
    .contact-section {
      padding: 0 0 6rem;
      position: relative;
      z-index: 10;
    }
    .contact-form-container {
      max-width: 600px;
      margin: 0 auto;
      padding: 3rem;
    }
    .form-group {
      margin-bottom: 1.5rem;
      text-align: left;
    }
    .form-group label {
      display: block;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-text-main);
      margin-bottom: 0.5rem;
    }
    .contact-form input,
    .contact-form textarea {
      width: 100%;
      padding: 1rem;
      border-radius: 12px;
      border: 1px solid rgba(0,0,0,0.1);
      background: rgba(255,255,255,0.7);
      font-family: inherit;
      color: var(--color-text-main);
      font-size: 1rem;
      transition: all 0.3s ease;
    }
    .contact-form input:focus,
    .contact-form textarea:focus {
      outline: none;
      border-color: var(--accent-3);
      background: white;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
    }
    .submit-btn {
      width: 100%;
      border: none;
      cursor: pointer;
      margin-bottom: 0;
      font-family: inherit;
      margin-top: 1rem;
    }

    /* Contact Footer */
    footer {
      padding: 6rem 0 4rem;
      text-align: center;
      position: relative;
      z-index: 10;
    }

    .cta-button {
      display: inline-block;
      padding: 1rem 3rem;
      font-size: 1.1rem;
      font-weight: 600;
      color: white;
      background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
      border-radius: 50px;
      text-decoration: none;
      box-shadow: 0 10px 25px rgba(13, 148, 136, 0.3);
      transition: all 0.3s ease;
      margin-bottom: 4rem;
    }

    .cta-button:hover {
      transform: translateY(-3px) scale(1.02);
      box-shadow: 0 15px 35px rgba(13, 148, 136, 0.4);
    }

    .footer-bottom {
      color: var(--color-text-light);
      font-size: 0.9rem;
    }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInDown {
      from { opacity: 0; transform: translateY(-20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Coin Block Easter Egg */
    .coin-block {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      width: 40px;
      height: 40px;
      background: #FAC000;
      border: 3px solid #8C5010;
      box-shadow: inset 0 0 0 2px #F8D830, 3px 3px 0 rgba(0,0,0,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 50;
      text-decoration: none;
      transition: transform 0.2s;
      image-rendering: pixelated;
    }
    .coin-block:hover {
      transform: translateY(-4px);
      box-shadow: inset 0 0 0 2px #F8D830, 3px 6px 0 rgba(0,0,0,0.2);
    }
    .coin-block:active {
      transform: translateY(2px);
      box-shadow: inset 0 0 0 2px #F8D830, 2px 2px 0 rgba(0,0,0,0.15);
    }
    .coin-block span {
      font-size: 1.1rem;
      font-weight: 900;
      color: #8C5010;
      line-height: 1;
    }

    @media (max-width: 768px) {
      .hero-title { font-size: 3rem; }
      .stats-row { flex-direction: column; gap: 1.5rem; }
      .exp-card { padding-left: 0; }
      .exp-track::before { display: none; }
      .exp-logo-wrap { position: relative; left: 0; margin-bottom: 1.5rem; }
      .edu-card { padding: 2rem; }
      .exp-content { padding: 2rem; }
    }
  </style>
</head>
<body>

  <!-- Dynamic Animated Background -->
  <div class="bg-animation">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <div class="container">
    <header>
      <div class="logo">AJMA</div>
      <nav class="nav-links">
        <a href="#experience">Experience</a>
        <a href="#education">Education</a>
        <a href="#patents">Patents</a>
        <a href="#projects">Projects</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main>
      <!-- Hero Section -->
      <section class="hero">
        <div>
          <div class="hero-badge">Leader & Builder</div>
          <h1 class="hero-title">Hello, I'm <br><span>{{ resume.name }}.</span></h1>
          <p class="hero-subtitle">{{ resume.subtitle }}</p>

          <div class="stats-row glass-panel">
            <div class="stat-item">
              <span class="stat-val">{{ resume.stats.yearsExperience }}+</span>
              <span class="stat-label">Years Eng Experience</span>
            </div>
            <div class="stat-item">
              <span class="stat-val">{{ resume.stats.yearsLeadership }}+</span>
              <span class="stat-label">Years Leadership</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
              <span class="stat-label">Companies</span>
              <div class="hero-logos">
                {% for company in resume.companies %}
                <img src="/images/logos/{{ company.id }}.png" alt="{{ company.id | capitalize }}">
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Philosophy / Strengths Summary -->
      <section class="summary-grid">
        {% for h in resume.highlights %}
        <div class="summary-card glass-panel">
          <div class="summary-icon">{{ h.emoji }}</div>
          <h3>{{ h.title }}</h3>
          <p>{{ h.description }}</p>
        </div>
        {% endfor %}
      </section>

      <!-- Experience -->
      <section id="experience" class="experience-section">
        <h2 class="section-title">Career Trajectory</h2>
        <div class="exp-track">
          {% for company in resume.companies %}
          <!-- {{ company.name }} -->
          <div class="exp-card">
            <div class="exp-logo-wrap">
              <img src="/images/logos/{{ company.id }}.png" class="exp-logo-img" alt="{{ company.id | capitalize }}">
            </div>
            <div class="exp-content glass-panel">
              <div class="exp-header">
                <div>
                  <h3 class="company-name">{{ company.name }}</h3>
                  <div class="company-meta">{{ company.location }}</div>
                </div>
                <div class="company-meta">{{ company.dateRange }}</div>
              </div>
              {% for role in company.roles %}
              <div class="role-group">
                <h4 class="role-title">{{ role.title }} {% if role.department %}<span class="period">{{ role.department | mdlinks | safe }}{% if role.period %} ({{ role.period }}){% endif %}</span>{% endif %}</h4>
                <ul class="role-desc">
                  {% for bullet in role.bullets %}
                  <li>{{ bullet | mdlinks | safe }}</li>
                  {% endfor %}
                </ul>
                {% if role.pressMentions %}
                <div class="press-badges">
                  {% for press in role.pressMentions %}
                  <a href="{{ press.url }}" class="press-badge">{{ press.name }}</a>
                  {% endfor %}
                </div>
                {% endif %}
              </div>
              {% endfor %}
            </div>
          </div>
          {% endfor %}
        </div>
      </section>

      <!-- Education -->
      <section id="education" class="edu-section">
        <h2 class="section-title">Education</h2>
        <div class="edu-card glass-panel">
          <div class="edu-year">{{ resume.education.year }}</div>
          <div>
            <div class="edu-school">{{ resume.education.school }}</div>
            <div class="edu-degree">{{ resume.education.degree }}</div>
            <p style="color: var(--color-text-muted);">{{ resume.education.location }} | {{ resume.education.detail }}</p>
          </div>
        </div>
      </section>

      <!-- Patents -->
      <section id="patents" class="edu-section">
        <h2 class="section-title">Patents</h2>
        <div class="exp-track">
          {% for patent in resume.patents %}
          <div class="exp-card">
            <div class="exp-content glass-panel">
              <div class="exp-header">
                <div>
                  <h3 class="company-name"><a href="{{ patent.url }}" style="color: inherit; text-decoration: none; border-bottom: 1px dashed var(--accent-2);">{{ patent.title }}</a></h3>
                  <div class="company-meta">{{ patent.number }}</div>
                </div>
                <div class="company-meta">Issued {{ patent.issued }}</div>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </section>

      <!-- Projects -->
      <section id="projects" class="experience-section">
        <h2 class="section-title">Personal Projects</h2>
        <div class="summary-grid">
          {% for project in projects %}
          <div class="summary-card glass-panel" style="cursor:pointer;" onclick="window.open('{{ project.github }}','_blank')">
            <div class="summary-icon">{{ project.emoji }}</div>
            <h3>{{ project.name }}</h3>
            <p>{{ project.summary }}</p>
            <div class="press-badges" style="margin-top:1rem;">
              <a href="{{ project.github }}" class="press-badge" onclick="event.stopPropagation()">GitHub</a>
              {% if project.chromeWebStore %}
              <a href="{{ project.chromeWebStore }}" class="press-badge" onclick="event.stopPropagation()">Chrome Web Store</a>
              {% endif %}
            </div>
          </div>
          {% endfor %}
        </div>
      </section>

    </main>

    <!-- Contact Section -->
    <section id="contact" class="contact-section">
      <h2 class="section-title">Get In Touch</h2>

      <div id="contact-btn-wrapper" style="text-align: center;">
        <button class="cta-button" onclick="document.getElementById('contact-btn-wrapper').style.display='none'; document.getElementById('contact-form-wrapper').style.display='block';">Say Hello</button>
      </div>

      <div id="contact-form-wrapper" class="glass-panel contact-form-container" style="display: none;">
        <form action="https://formspree.io/f/mwvrbook" method="POST" class="contact-form">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required placeholder="John Doe">
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="_replyto" required placeholder="john@example.com">
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" required placeholder="How can we work together?"></textarea>
